PGRELAY_ENV=dev
PGRELAY_DATABASE_URL=postgresql+asyncpg://pgrelay:pgrelay@postgres:5432/pgrelay
PGRELAY_API_HOST=0.0.0.0
PGRELAY_API_PORT=8090
PGRELAY_API_AUTH_TOKENS=dev-token-change-me
PGRELAY_WORKER_ID_PREFIX=worker
PGRELAY_WORKER_QUEUES=default
PGRELAY_WORKER_CONCURRENCY=8
PGRELAY_WORKER_BATCH_SIZE=8
PGRELAY_WORKER_POLL_INTERVAL_SECONDS=1.0
PGRELAY_WORKER_LEASE_SECONDS=60
PGRELAY_WORKER_SHUTDOWN_GRACE_SECONDS=20
PGRELAY_DB_POOL_SIZE=12
PGRELAY_DB_MAX_OVERFLOW=4
PGRELAY_DB_POOL_TIMEOUT_SECONDS=30
PGRELAY_DB_STATEMENT_TIMEOUT_MS=30000
PGRELAY_DB_LOCK_TIMEOUT_MS=5000
PGRELAY_RETRY_BASE_SECONDS=2
PGRELAY_RETRY_MAX_SECONDS=900
PGRELAY_RETRY_JITTER_RATIO=0.2
PGRELAY_HTTP_DEFAULT_TIMEOUT_SECONDS=20
PGRELAY_HTTP_MAX_TIMEOUT_SECONDS=120
PGRELAY_HTTP_ALLOWED_HOSTS=example.com,localhost
PGRELAY_BLOCK_PRIVATE_NETWORK_TARGETS=true
PGRELAY_HTTP_MAX_CONNECTIONS=100
PGRELAY_HTTP_MAX_KEEPALIVE_CONNECTIONS=20
PGRELAY_RETENTION_SUCCEEDED_DAYS=7
PGRELAY_RETENTION_DEAD_LETTER_DAYS=30
PGRELAY_PURGE_BATCH_SIZE=1000
PGRELAY_MAX_PAYLOAD_BYTES=262144
PGRELAY_MAX_HEADERS_BYTES=16384
PGRELAY_MAX_METADATA_BYTES=16384
PGRELAY_LOG_LEVEL=INFO
